{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=MyAppDb;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Key": "REPLACE_WITH_ENV_VAR_JWT_SECRET_KEY_MIN_32_CHARS",
    "Issuer": "dot-net-core-rest-api",
    "Audience": "dot-net-core-rest-api-clients"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  }
}
